<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left minor peak -->
    <path android:pathData="M30,42 L46,64 L18,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="18" android:startY="42" android:endX="46" android:endY="64">
                <item android:color="#FFB74D" android:offset="0.0" />
                <item android:color="#FF7043" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right minor peak -->
    <path android:pathData="M78,42 L90,64 L62,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="62" android:startY="42" android:endX="90" android:endY="64">
                <item android:color="#FFB74D" android:offset="0.0" />
                <item android:color="#FF7043" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center main peak (zenith) -->
    <path android:pathData="M54,25 L70,64 L38,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="38" android:startY="25" android:endX="70" android:endY="64">
                <item android:color="#FFE082" android:offset="0.0" />
                <item android:color="#FFA726" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Snow cap highlight on main peak -->
    <path
        android:pathData="M54,25 L60,38 L48,38 Z"
        android:fillColor="#FFFDF7" />

    <!-- Left page of open book -->
    <path
        android:pathData="M54,55 L54,84 L27,76 Q25,75.4 25,73.4 L25,50 Q25,47 28,48 L54,55 Z"
        android:fillColor="#F5F3FA" />

    <!-- Right page of open book -->
    <path
        android:pathData="M54,55 L54,84 L81,76 Q83,75.4 83,73.4 L83,50 Q83,47 80,48 L54,55 Z"
        android:fillColor="#FFFFFF" />

    <!-- Spine shadow -->
    <path
        android:pathData="M52.6,55 L55.4,55 L55.4,84 L52.6,84 Z"
        android:fillColor="#C8C3DA" />

</vector>
